NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

SUPABASE_URL=https://bjesduasnzbzywofukbf.supabase.co

# Modern publishable key (format: sb_publishable_*). Legacy "anon" JWT also works.
SUPABASE_ANON_KEY=

# Modern secret key (format: sb_secret_*). Legacy "service_role" JWT also works.
SUPABASE_SERVICE_ROLE_KEY=

# Optional. Only required to accept tokens still signed with the legacy HS256
# "previous key" during Supabase's asymmetric JWT migration. New ES256 tokens
# are verified via JWKS automatically.
SUPABASE_JWT_LEGACY_SECRET=

CORS_ORIGINS=http://localhost:3000
SWAGGER_ENABLED=true

# ===== Google Calendar (app -> Calendar sync) =====
# Set to true to enable syncing vuelos to Google Calendar.
GOOGLE_CALENDAR_SYNC_ENABLED=false
# Target calendar id: shared "aerochartercancunflightplanner" calendar
# (an email like info@vuelatour.com or a *@group.calendar.google.com id).
GOOGLE_CALENDAR_ID=
# Full service-account JSON on a SINGLE line (do not wrap in quotes).
# The service account must have "Make changes to events" on the calendar above.
GOOGLE_SERVICE_ACCOUNT_JSON=

# ===== Email (Resend) =====
# API key de Resend. Vacío = no se envían correos (no-op).
RESEND_API_KEY=
# Remitente verificado en Resend.
RESEND_FROM=Vuelatour Notificaciones <notificaciones@notify.vuelatour.com>

# ===== pyservices (IA / visión) =====
# Base URL del microservicio FastAPI. Vacío = visión por IA deshabilitada
# (captura cae a manual + sugerencia histórica).
PYSERVICES_BASE_URL=http://localhost:8000
# Token compartido (header X-Internal-Token). Debe coincidir con pyservices.
INTERNAL_SHARED_TOKEN=
PYSERVICES_TIMEOUT_MS=30000
